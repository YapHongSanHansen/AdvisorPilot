# Project Atlas — environment template. Copy to .env.local and fill in.
# .env.local is git-ignored; never commit real secrets.

# --- Supabase (database) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only (never exposed to the browser):
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- Optional: LLM for drafting work-style profiles ---
# Used only to draft structured work-style data from approved artifacts.
# It NEVER makes the final allocation decision.
ANTHROPIC_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_NAME=Project Atlas
